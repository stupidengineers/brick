        "test": "./test.sh"
    },
    "devDependencies": {
        "@biomejs/biome": "1.9.4",
        "@types/node": "25.9.1",
        "husky": "9.1.7",
        "tsx": "4.19.4",
        "typescript": "5.8.3"
    }
}
